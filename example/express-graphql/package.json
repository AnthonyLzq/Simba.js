{
  "name": "example-express-graphql",
  "version": "0.1.0",
  "main": "src/index.ts",
  "description": "This is a test using Express with GraphQL with Prisma and PostgreSQL",
  "scripts": {
    "lint": "biome check --write src/",
    "service": "nodemon",
    "start": "tsx src/index.ts",
    "release": "standard-version",
    "test:ci": "vitest run",
    "test:local": "NODE_ENV=local vitest run"
  },
  "author": "AnthonyLzq <sluzquinosa@uni.pe>",
  "license": "MIT",
  "dependencies": {
    "@apollo/server": "^5.4.0",
    "@as-integrations/express5": "^1.1.2",
    "@asteasolutions/zod-to-openapi": "^8.4.1",
    "@prisma/client": "^6.19.2",
    "class-validator": "^0.14.4",
    "cors": "^2.8.6",
    "debug": "^4.4.3",
    "express": "^5.2.1",
    "graphql": "^16.13.0",
    "graphql-scalars": "^1.25.0",
    "http-errors": "^2.0.1",
    "pg": "^8.19.0",
    "pg-hstore": "^2.3.4",
    "reflect-metadata": "^0.2.2",
    "swagger-ui-express": "^5.0.1",
    "type-graphql": "2.0.0-rc.3",
    "zod": "^4.3.6"
  },
  "nodemonConfig": {
    "watch": [
      ".env",
      "src"
    ],
    "ext": "ts",
    "ignore": [
      "src/**/*.test.ts"
    ],
    "exec": "DEBUG=App:* npx tsx -r dotenv/config ./src/index"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.4",
    "@swc/core": "^1.15.13",
    "@types/cors": "^2.8.19",
    "@types/debug": "^4.1.12",
    "@types/express": "^5.0.6",
    "@types/http-errors": "^2.0.5",
    "@types/node": "^25.3.0",
    "@types/swagger-ui-express": "^4.1.8",
    "axios": "^1.13.5",
    "dotenv": "^17.3.1",
    "nodemon": "^3.1.14",
    "prisma": "^6.19.2",
    "standard-version": "^9.5.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "unplugin-swc": "^1.5.9",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.0.18"
  }
}
