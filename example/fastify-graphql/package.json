{
  "name": "example-fastify-graphql",
  "version": "0.1.0",
  "main": "src/index.ts",
  "description": "This is a test using Fastify with GraphQL with Prisma and PostgreSQL",
  "scripts": {
    "lint": "biome check --write src/",
    "service": "nodemon",
    "start": "ts-node src/index.ts",
    "release": "standard-version",
    "test:ci": "jest --ci -i",
    "test:local": "NODE_ENV=local jest --ci -i --setupFiles dotenv/config"
  },
  "author": "AnthonyLzq <sluzquinosa@uni.pe>",
  "license": "MIT",
  "dependencies": {
    "@apollo/server": "^5.4.0",
    "@as-integrations/fastify": "^3.1.0",
    "@fastify/cors": "^11.2.0",
    "@fastify/swagger": "^9.7.0",
    "@fastify/swagger-ui": "^5.2.5",
    "@prisma/client": "^6.19.2",
    "class-validator": "^0.14.3",
    "debug": "^4.4.3",
    "fastify": "^5.7.4",
    "fastify-type-provider-zod": "^6.1.0",
    "graphql": "^16.13.0",
    "graphql-scalars": "^1.25.0",
    "http-errors": "^2.0.1",
    "pg": "^8.18.0",
    "pg-hstore": "^2.3.4",
    "reflect-metadata": "^0.2.2",
    "type-graphql": "2.0.0-rc.3",
    "zod": "^4.3.6"
  },
  "nodemonConfig": {
    "watch": [
      ".env",
      "src"
    ],
    "ext": "ts",
    "ignore": [
      "src/**/*.test.ts"
    ],
    "exec": "DEBUG=App:* npx ts-node -r dotenv/config ./src/index"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.4",
    "@jest/types": "^30.2.0",
    "@types/debug": "^4.1.12",
    "@types/http-errors": "^2.0.5",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.3.0",
    "axios": "^1.13.5",
    "dotenv": "^17.3.1",
    "jest": "^30.2.0",
    "jest-unit": "^0.0.2",
    "nodemon": "^3.1.14",
    "prisma": "^6.19.2",
    "standard-version": "^9.5.0",
    "ts-jest": "^29.4.6",
    "ts-loader": "^9.5.4",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.9.3"
  }
}
