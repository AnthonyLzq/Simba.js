{
  "name": "example-hono-mongo-graphql",
  "version": "0.1.0",
  "main": "src/index.ts",
  "description": "This is a test using Hono with GraphQL with Prisma and MongoDB",
  "scripts": {
    "lint": "biome check --write src/",
    "service": "nodemon",
    "start": "ts-node src/index.ts",
    "release": "standard-version",
    "test:ci": "jest --ci -i",
    "test:local": "NODE_ENV=local jest --ci -i --setupFiles dotenv/config"
  },
  "author": "AnthonyLzq <sluzquinosa@uni.pe>",
  "license": "MIT",
  "dependencies": {
    "@apollo/server": "^5.4.0",
    "@hono/node-server": "^1.19.9",
    "@hono/swagger-ui": "^0.5.3",
    "@hono/zod-openapi": "^1.2.2",
    "@prisma/client": "^6.19.2",
    "class-validator": "^0.14.3",
    "debug": "^4.4.3",
    "graphql": "^16.13.0",
    "graphql-scalars": "^1.25.0",
    "hono": "^4.12.2",
    "http-errors": "^2.0.1",
    "mongodb": "^7.1.0",
    "reflect-metadata": "^0.2.2",
    "type-graphql": "2.0.0-rc.3",
    "zod": "^4.3.6"
  },
  "nodemonConfig": {
    "watch": [
      ".env",
      "src"
    ],
    "ext": "ts",
    "ignore": [
      "src/**/*.test.ts"
    ],
    "exec": "DEBUG=App:* npx ts-node -r dotenv/config ./src/index"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.4",
    "@jest/types": "^30.2.0",
    "@types/debug": "^4.1.12",
    "@types/http-errors": "^2.0.5",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.3.0",
    "axios": "^1.13.5",
    "dotenv": "^17.3.1",
    "jest": "^30.2.0",
    "jest-unit": "^0.0.2",
    "nodemon": "^3.1.14",
    "prisma": "^6.19.2",
    "standard-version": "^9.5.0",
    "ts-jest": "^29.4.6",
    "ts-loader": "^9.5.4",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.9.3"
  }
}
