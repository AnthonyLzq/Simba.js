{
  "name": "example-express",
  "version": "0.1.0",
  "main": "src/index.ts",
  "description": "This is a test using Express with Prisma and PostgreSQL",
  "scripts": {
    "lint": "biome check --write src/",
    "service": "nodemon",
    "start": "ts-node src/index.ts",
    "release": "standard-version",
    "test:ci": "jest --ci -i",
    "test:local": "NODE_ENV=local jest --ci -i --setupFiles dotenv/config"
  },
  "author": "AnthonyLzq <sluzquinosa@uni.pe>",
  "license": "MIT",
  "dependencies": {
    "@prisma/client": "^6.19.2",
    "cors": "^2.8.6",
    "debug": "^4.4.3",
    "express": "^5.2.1",
    "http-errors": "^2.0.1",
    "pg": "^8.18.0",
    "pg-hstore": "^2.3.4",
    "swagger-ui-express": "^5.0.1",
    "zod": "^4.3.6"
  },
  "nodemonConfig": {
    "watch": [
      ".env",
      "src"
    ],
    "ext": "ts",
    "ignore": [
      "src/**/*.test.ts"
    ],
    "exec": "DEBUG=App:* npx ts-node -r dotenv/config ./src/index"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.4",
    "@jest/types": "^30.2.0",
    "@types/cors": "^2.8.19",
    "@types/debug": "^4.1.12",
    "@types/express": "^5.0.6",
    "@types/http-errors": "^2.0.5",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.3.0",
    "@types/swagger-ui-express": "^4.1.8",
    "axios": "^1.13.5",
    "dotenv": "^17.3.1",
    "jest": "^30.2.0",
    "jest-unit": "^0.0.2",
    "nodemon": "^3.1.14",
    "prisma": "^6.19.2",
    "standard-version": "^9.5.0",
    "ts-jest": "^29.4.6",
    "ts-loader": "^9.5.4",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.9.3"
  }
}
