{
  "name": "example-hono-mongo",
  "version": "0.1.0",
  "main": "src/index.ts",
  "description": "This is a test using Hono with Prisma and MongoDB",
  "scripts": {
    "lint": "biome check --write src/",
    "service": "nodemon",
    "start": "tsx src/index.ts",
    "release": "commit-and-tag-version",
    "test:ci": "vitest run",
    "test:local": "NODE_ENV=local vitest run"
  },
  "author": "AnthonyLzq <sluzquinosa@uni.pe>",
  "license": "MIT",
  "dependencies": {
    "@hono/node-server": "^1.19.9",
    "@hono/swagger-ui": "^0.5.3",
    "@hono/zod-openapi": "^1.2.2",
    "@prisma/client": "^6.19.2",
    "debug": "^4.4.3",
    "hono": "^4.12.2",
    "http-errors": "^2.0.1",
    "mongodb": "^7.1.0",
    "zod": "^4.3.6"
  },
  "nodemonConfig": {
    "watch": [
      ".env",
      "src"
    ],
    "ext": "ts",
    "ignore": [
      "src/**/*.test.ts"
    ],
    "exec": "DEBUG=App:* npx tsx -r dotenv/config ./src/index"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.4",
    "@types/debug": "^4.1.12",
    "@types/http-errors": "^2.0.5",
    "@types/node": "^25.3.1",
    "axios": "^1.13.5",
    "commit-and-tag-version": "^12.6.1",
    "dotenv": "^17.3.1",
    "nodemon": "^3.1.14",
    "prisma": "^6.19.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.0.18"
  }
}
