import 'reflect-metadata'
import { Field, <%- dbIsSQL ? 'Int' : 'ID' %>, ObjectType } from 'type-graphql'

@ObjectType()
class <%- Entity %> {
  @Field(() => <%- dbIsSQL ? 'Int' : 'ID' %>)
  id!: number

<% entityFields.forEach(function(f) { -%>
  @Field()
  <%- f.name %>!: string

<% }) -%>
  @Field({ nullable: true })
  createdAt?: string

  @Field({ nullable: true })
  updatedAt?: string
}

export { <%- Entity %> }
