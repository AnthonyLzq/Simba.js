import type { OpenAPIHono } from '@hono/zod-openapi'
import z from 'zod'

import { response } from 'network/response'
import { jsonBody, jsonResponse } from 'network/utils'
import { <%- entity %>Dto, idSchema, store<%- Entity %>Dto } from 'schemas'
import { <%- Entity %>Service } from 'services'

const <%- Entity %> = (app: OpenAPIHono, prefix = '/api'): void => {
  const <%- entity %>Tag = '<%- entity %>'
  const registry = app.openAPIRegistry

  // POST /<%- entities %>
  app.post(`${prefix}/<%- entities %>`, async c => {
    const {
      args: { <%- entityFields.map(f => f.name).join(', ') %> }
    } = store<%- Entity %>Dto.parse(await c.req.json())
    const us = new <%- Entity %>Service()
    const <%- entity %> = await us.store({ <%- entityFields.map(f => f.name).join(', ') %> })

    return response({ error: false, message: <%- entity %>, c, status: 201 })
  })

  registry.registerPath({
    method: 'post',
    path: '/<%- entities %>',
    tags: [<%- entity %>Tag],
    request: {
      body: jsonBody(store<%- Entity %>Dto)
    },
    responses: {
      201: jsonResponse(<%- entity %>Dto, '<%- Entity %> created successfully')
    }
  })

  // GET /<%- entity %>/:id
  app.get(`${prefix}/<%- entity %>/:id`, async c => {
    const { id } = idSchema.parse({ id: c.req.param('id') })
    const us = new <%- Entity %>Service()
    const <%- entity %> = await us.getById(id)

    return response({ error: false, message: <%- entity %>, c, status: 200 })
  })

  registry.registerPath({
    method: 'get',
    path: '/<%- entity %>/{id}',
    tags: [<%- entity %>Tag],
    request: {
      params: idSchema
    },
    responses: {
      200: jsonResponse(<%- entity %>Dto, '<%- Entity %> found')
    }
  })

  // PATCH /<%- entity %>/:id
  app.patch(`${prefix}/<%- entity %>/:id`, async c => {
    const {
      args: { <%- entityFields.map(f => f.name).join(', ') %> }
    } = store<%- Entity %>Dto.parse(await c.req.json())
    const { id } = idSchema.parse({ id: c.req.param('id') })
    const us = new <%- Entity %>Service()
    const <%- entity %> = await us.update(id, { <%- entityFields.map(f => f.name).join(', ') %> })

    return response({ error: false, message: <%- entity %>, c, status: 200 })
  })

  registry.registerPath({
    method: 'patch',
    path: '/<%- entity %>/{id}',
    tags: [<%- entity %>Tag],
    request: {
      params: idSchema,
      body: jsonBody(store<%- Entity %>Dto)
    },
    responses: {
      200: jsonResponse(<%- entity %>Dto, '<%- Entity %> updated successfully')
    }
  })

  // DELETE /<%- entity %>/:id
  app.delete(`${prefix}/<%- entity %>/:id`, async c => {
    const { id } = idSchema.parse({ id: c.req.param('id') })
    const us = new <%- Entity %>Service()
    const result = await us.deleteById(id)

    return response({ error: false, message: result, c, status: 200 })
  })

  registry.registerPath({
    method: 'delete',
    path: '/<%- entity %>/{id}',
    tags: [<%- entity %>Tag],
    request: {
      params: idSchema
    },
    responses: {
      200: jsonResponse(z.string(), '<%- Entity %> deleted successfully')
    }
  })
}

export { <%- Entity %> }
