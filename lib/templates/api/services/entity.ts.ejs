import debug from 'debug'

import { getById, removeById, store, update } from 'database'
import { Id, <%- Entity %> as <%- Entity %>Schema } from 'schemas'
import { BaseHttpService } from './BaseHttp'
import { EFU, MFU, GE } from './utils'

class <%- Entity %>Service extends BaseHttpService {
  constructor() {
    super(debug('App:Services:<%- Entity %>'))
  }

  async store(<%- entity %>Dto: <%- Entity %>Schema) {
    try {
      const result = await store(<%- entity %>Dto)
      super.log({ method: this.store.name, value: 'result', content: result })

      return result
    } catch (e) {
      return super.errorHandling(e)
    }
  }

  async getById(id: Id) {
    try {
      const <%- entity %> = await getById(id)
      super.log({ method: this.getById.name, value: 'result', content: <%- entity %> })

      if (!<%- entity %>)
        return super.errorHandling(new Error(EFU.NOT_FOUND), { code: '404' })

      return <%- entity %>
    } catch (e) {
      return super.errorHandling(e)
    }
  }

  async update(id: Id, <%- entity %>: <%- Entity %>Schema) {
    try {
      const updated<%- Entity %> = await update(id, <%- entity %>)
      super.log({
        method: this.update.name,
        value: 'result',
        content: updated<%- Entity %>
      })

      if (!updated<%- Entity %>)
        return super.errorHandling(new Error(EFU.NOT_FOUND), { code: '404' })

      return updated<%- Entity %>
    } catch (e) {
      return super.errorHandling(e, { message: GE.INTERNAL_SERVER_ERROR })
    }
  }

  async deleteById(id: Id) {
    try {
      const deleted<%- Entity %> = await removeById(id)
      super.log({
        method: this.deleteById.name,
        value: 'result',
        content: deleted<%- Entity %>
      })

      if (!deleted<%- Entity %>)
        return super.errorHandling(new Error(EFU.NOT_FOUND), { code: '404' })

      return MFU.<%- Entity.toUpperCase() %>_DELETED
    } catch (e) {
      return super.errorHandling(e)
    }
  }
}

export { <%- Entity %>Service }
