import type { FastifyInstance } from 'fastify'
import type { ZodTypeProvider } from 'fastify-type-provider-zod'
import z from 'zod'

import { response } from 'network/response'
import { <%- entity %>Dto, idSchema, store<%- Entity %>Dto } from 'schemas'
import { <%- Entity %>Service } from 'services'

const <%- Entity %> = (app: FastifyInstance, prefix = '/api'): void => {
  app
    .withTypeProvider<ZodTypeProvider>()
    .post(
      `${prefix}/<%- entities %>`,
      {
        schema: {
          body: store<%- Entity %>Dto,
          response: {
            201: z.object({
              error: z.boolean(),
              message: <%- entity %>Dto
            })
          },
          tags: ['<%- entity %>']
        }
      },
      async (request, reply) => {
        const {
          body: {
            args: { <%- entityFields.map(f => f.name).join(', ') %> }
          }
        } = request
        const us = new <%- Entity %>Service()
        const <%- entity %> = await us.store({ <%- entityFields.map(f => f.name).join(', ') %> })

        response({ error: false, message: <%- entity %>, reply, status: 201 })
      }
    )
    .get(
      `${prefix}/<%- entity %>/:id`,
      {
        schema: {
          params: idSchema,
          response: {
            200: z.object({
              error: z.boolean(),
              message: <%- entity %>Dto
            })
          },
          tags: ['<%- entity %>']
        }
      },
      async (request, reply) => {
        const {
          params: { id }
        } = request
        const us = new <%- Entity %>Service()
        const <%- entity %> = await us.getById(id)

        response({ error: false, message: <%- entity %>, reply, status: 200 })
      }
    )
    .patch(
      `${prefix}/<%- entity %>/:id`,
      {
        schema: {
          body: store<%- Entity %>Dto,
          params: idSchema,
          response: {
            200: z.object({
              error: z.boolean(),
              message: <%- entity %>Dto
            })
          },
          tags: ['<%- entity %>']
        }
      },
      async (request, reply) => {
        const {
          body: {
            args: { <%- entityFields.map(f => f.name).join(', ') %> }
          },
          params: { id }
        } = request
        const us = new <%- Entity %>Service()
        const <%- entity %> = await us.update(id, { <%- entityFields.map(f => f.name).join(', ') %> })

        response({ error: false, message: <%- entity %>, reply, status: 200 })
      }
    )
    .delete(
      `${prefix}/<%- entity %>/:id`,
      {
        schema: {
          params: idSchema,
          response: {
            200: z.object({
              error: z.boolean(),
              message: z.string()
            })
          },
          tags: ['<%- entity %>']
        }
      },
      async (request, reply) => {
        const {
          params: { id }
        } = request
        const us = new <%- Entity %>Service()
        const result = await us.deleteById(id)

        response({ error: false, message: result, reply, status: 200 })
      }
    )
}

export { <%- Entity %> }
