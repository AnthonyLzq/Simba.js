import fastifySwagger from '@fastify/swagger'
import fastifySwaggerUi from '@fastify/swagger-ui'
import type { FastifyInstance } from 'fastify'
import { jsonSchemaTransform } from 'fastify-type-provider-zod'

const Docs = async (app: FastifyInstance, prefix = '/api') => {
  await app.register(fastifySwagger, {
    openapi: {
      info: {
        title: 'Test swagger',
        description: 'Testing the Fastify swagger API',
        version: '0.1.0',
        contact: {
          email: '<%- email %>'
        },
        license: {
          name: 'MIT',
          url: 'https://opensource.org/licenses/MIT'
        }
      },
      servers: [
        {
          url: 'http://localhost:1996/api',
          description: '<%- projectName %> local API'
        }
      ],
      tags: [
        {
          name: '<%- entity %>',
          description: '<%- Entity %> related endpoints'
        }
      ]
    },
    transform: jsonSchemaTransform
  })
  await app.register(fastifySwaggerUi, { routePrefix: `${prefix}/docs` })
}

export { Docs }
