import 'reflect-metadata'
import { Field, <%- dbIsSQL ? 'Int' : 'ID' %>, ObjectType } from 'type-graphql'

@ObjectType()
class User {
  @Field(() => <%- dbIsSQL ? 'Int' : 'ID' %>)
  id!: number

  @Field()
  lastName!: string

  @Field()
  name!: string

  @Field({ nullable: true })
  createdAt?: string

  @Field({ nullable: true })
  updatedAt?: string
}

export { User }
