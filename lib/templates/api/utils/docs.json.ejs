{
  "openapi": "3.0.0",
  "info": {
    "title": "<%- projectName %>",
    "description": "Documentation of the test",
    "contact": {
      "email": "<%- email %>"
    },
    "license": {
      "name": "MIT",
      "url": "https://opensource.org/licenses/MIT"
    },
    "version": "<%- projectVersion %>"
  },
  "servers": [
    {
      "url": "http://localhost:1996/api",
      "description": "<%- projectName %> local API"
    }
  ],
  "tags": [
    {
      "name": "<%- entity %>",
      "description": "Operations related to the <%- entity %>"
    }
  ]<% if (!graphQL) { %>,
  "paths": {
    "/<%- entities %>": {
      "post": {
        "tags": [
          "<%- entity %>"
        ],
        "summary": "Save a <%- entity %> in the database",
        "operationId": "store",
        "requestBody": {
          "$ref": "#/components/requestBodies/<%- Entity %>DTO"
        },
        "responses": {
          "201": {
            "description": "<%- Entity %> successfully stored",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/<%- Entity %>"
                }
              }
            }
          },
          "422": {
            "description": "Invalid request format",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DefaultError"
                }
              }
            }
          },
          "500": {
            "description": "Internal server error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DefaultError"
                }
              }
            }
          }
        }
      }
    },
    "/<%- entity %>/{id}": {
      "get": {
        "tags": [
          "<%- entity %>"
        ],
        "summary": "Get a specific <%- entity %>",
        "operationId": "getOne",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "description": "<%- Entity %> id",
            "required": true,
            "style": "simple",
            "explode": false,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "<%- Entity %> stored in the database",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/<%- Entity %>"
                }
              }
            }
          },
          "404": {
            "description": "<%- Entity %> not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DefaultError"
                }
              }
            }
          },
          "422": {
            "description": "Invalid request format",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DefaultError"
                }
              }
            }
          },
          "500": {
            "description": "Internal server error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DefaultError"
                }
              }
            }
          }
        }
      },
      "patch": {
        "tags": [
          "<%- entity %>"
        ],
        "summary": "Update the <%- entity %> data",
        "operationId": "update",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "description": "<%- Entity %> id",
            "required": true,
            "style": "simple",
            "explode": false,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "$ref": "#/components/requestBodies/<%- Entity %>DTO"
        },
        "responses": {
          "200": {
            "description": "<%- Entity %> successfully updated",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/<%- Entity %>"
                }
              }
            }
          },
          "404": {
            "description": "<%- Entity %> not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DefaultError"
                }
              }
            }
          },
          "422": {
            "description": "Invalid request format",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DefaultError"
                }
              }
            }
          },
          "500": {
            "description": "Internal server error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DefaultError"
                }
              }
            }
          }
        }
      },
      "delete": {
        "tags": [
          "<%- entity %>"
        ],
        "summary": "Delete one <%- entity %> from the database",
        "operationId": "delete",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "description": "<%- Entity %> id",
            "required": true,
            "style": "simple",
            "explode": false,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "<%- Entity %> successfully deleted",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DefaultSuccess"
                }
              }
            }
          },
          "404": {
            "description": "<%- Entity %> not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DefaultError"
                }
              }
            }
          },
          "422": {
            "description": "Invalid request format",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DefaultError"
                }
              }
            }
          },
          "500": {
            "description": "Internal server error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DefaultError"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "<%- Entity %>": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
<% entityFields.forEach(function(f, i) { -%>
          "<%- f.name %>": {
            "type": "string"
          }<%- i < entityFields.length - 1 ? ',' : '' %>
<% }) -%>
        }
      },
      "DefaultSuccess": {
        "type": "object",
        "properties": {
          "error": {
            "type": "boolean",
            "default": false
          },
          "message": {
            "type": "object",
            "properties": {
              "result": {
                "type": "string"
              }
            }
          }
        }
      },
      "DefaultError": {
        "type": "object",
        "properties": {
          "error": {
            "type": "boolean",
            "default": true
          },
          "message": {
            "type": "object",
            "properties": {
              "result": {
                "type": "string"
              }
            }
          }
        }
      }
    },
    "requestBodies": {
      "<%- Entity %>DTO": {
        "description": "<%- Entity %> data",
        "content": {
          "application/json": {
            "schema": {
              "type": "object",
              "properties": {
                "args": {
                  "type": "object",
                  "properties": {
<% entityFields.forEach(function(f, i) { -%>
                    "<%- f.name %>": {
                      "type": "string"
                    }<%- i < entityFields.length - 1 ? ',' : '' %>
<% }) -%>
                  }
                }
              }
            }
          }
        },
        "required": true
      }
    }
  }
  }<% } else { %>
}<% } %>