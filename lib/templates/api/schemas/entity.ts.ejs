import z from 'zod'

import { id } from './id'

const <%- entity %> = z.object({
<% entityFields.forEach(function(f, i) { -%>
  <%- f.name %>: <%- f.zodType %><%= i < entityFields.length - 1 ? ',' : '' %>
<% }) -%>
})

type <%- Entity %> = z.infer<typeof <%- entity %>>

const <%- entity %>WithId = <%- entity %>.extend({ id })

type <%- Entity %>WithId = z.infer<typeof <%- entity %>WithId>

const <%- entity %>Dto = z.object({
  id: id.optional(),
<% entityFields.forEach(function(f) { -%>
  <%- f.name %>: <%- f.zodType %>,
<% }) -%>
  createdAt: z.string().optional(),
  updatedAt: z.string().optional()
})

type <%- Entity %>DTO = z.infer<typeof <%- entity %>Dto>

const store<%- Entity %>Dto = z.object({
  args: <%- entity %>
})

type Store<%- Entity %>DTO = z.infer<typeof store<%- Entity %>Dto>

export {
  <%- entity %>Dto,
  <%- Entity %>DTO,
  <%- entity %>WithId,
  <%- Entity %>WithId,
  <%- entity %>,
  <%- Entity %>,
  store<%- Entity %>Dto,
  Store<%- Entity %>DTO
}
